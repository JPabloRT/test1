# ============================================
# Supabase Edge Functions - Variables de Entorno
# ============================================
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repositorio.

# --- Supabase ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# --- Microsoft Graph (para enviar correos) ---
MS_TENANT_ID=tu-tenant-id
MS_CLIENT_ID=tu-client-id
MS_CLIENT_SECRET=tu-client-secret
MS_SENDER_USER_ID=tu-sender-user-id

# --- Buzones de correo destino ---
REGISTRATION_MAILBOX_ADDRESS=registros@tuempresa.com
FEEDBACK_MAILBOX_ADDRESS=quejas@tuempresa.com
STATUS_MAILBOX_ADDRESS=estatus@tuempresa.com
